  "templates": {
    "systemInfo": {
      "title": "Información del sistema",
      "body": "uname -a\necho '---'\ndf -h\necho '---'\nfree -h 2>/dev/null || vm_stat",
      "tags": "system"
    },
    "diskUsage": {
      "title": "Uso de disco (top 10)",
      "body": "du -sh /* 2>/dev/null | sort -rh | head -10",
      "tags": "system, disk"
    },
    "listeningPorts": {
      "title": "Puertos en escucha",
      "body": "ss -tlnp 2>/dev/null || netstat -an | grep LISTEN",
      "tags": "network, system"
    },
    "dockerContainers": {
      "title": "Contenedores Docker",
      "body": "docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'",
      "tags": "docker"
    },
    "dockerCleanup": {
      "title": "Limpieza Docker",
      "body": "docker system prune -af --volumes",
      "tags": "docker"
    },
    "gitLog": {
      "title": "Git log (compacto)",
      "body": "git log --oneline --graph --decorate --all -20",
      "tags": "git"
    },
    "topProcesses": {
      "title": "Procesos principales (CPU)",
      "body": "ps aux --sort=-%cpu | head -10",
      "tags": "system"
    },
    "nginxReload": {
      "title": "Recargar Nginx",
      "body": "sudo nginx -t && sudo systemctl reload nginx",
      "tags": "nginx, ops"
    },
    "sslCertCheck": {
      "title": "Comprobar certificado SSL",
      "body": "echo | openssl s_client -servername example.com -connect example.com:443 2>/dev/null | openssl x509 -noout -dates",
      "tags": "ssl, ops"
    },
    "journalErrors": {
      "title": "Errores del journal (última hora)",
      "body": "journalctl --since '1 hour ago' -p err --no-pager",
      "tags": "system, logs"
    }
  }
}
