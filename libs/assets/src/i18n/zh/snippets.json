  "templates": {
    "systemInfo": {
      "title": "系统信息",
      "body": "uname -a\necho '---'\ndf -h\necho '---'\nfree -h 2>/dev/null || vm_stat",
      "tags": "system"
    },
    "diskUsage": {
      "title": "磁盘用量（前 10）",
      "body": "du -sh /* 2>/dev/null | sort -rh | head -10",
      "tags": "system, disk"
    },
    "listeningPorts": {
      "title": "监听端口",
      "body": "ss -tlnp 2>/dev/null || netstat -an | grep LISTEN",
      "tags": "network, system"
    },
    "dockerContainers": {
      "title": "Docker 容器",
      "body": "docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'",
      "tags": "docker"
    },
    "dockerCleanup": {
      "title": "Docker 清理",
      "body": "docker system prune -af --volumes",
      "tags": "docker"
    },
    "gitLog": {
      "title": "Git 日志（简洁）",
      "body": "git log --oneline --graph --decorate --all -20",
      "tags": "git"
    },
    "topProcesses": {
      "title": "CPU 占用最高的进程",
      "body": "ps aux --sort=-%cpu | head -10",
      "tags": "system"
    },
    "nginxReload": {
      "title": "Nginx 重载",
      "body": "sudo nginx -t && sudo systemctl reload nginx",
      "tags": "nginx, ops"
    },
    "sslCertCheck": {
      "title": "SSL 证书检查",
      "body": "echo | openssl s_client -servername example.com -connect example.com:443 2>/dev/null | openssl x509 -noout -dates",
      "tags": "ssl, ops"
    },
    "journalErrors": {
      "title": "Journal 错误（最近一小时）",
      "body": "journalctl --since '1 hour ago' -p err --no-pager",
      "tags": "system, logs"
    }
  }
}
