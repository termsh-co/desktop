{
  "name": "@termsh/desktop",
  "private": true,
  "version": "0.0.0",
  "description": "termsh desktop — Electron + Angular",
  "main": "electron/main.js",
  "scripts": {
    "build:web": "ng build desktop --configuration production",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "pnpm build:electron && electron .",
    "electron:start": "pnpm build:electron && node scripts/dev-electron.mjs",
    "check-i18n": "node scripts/check-i18n-keys.mjs",
    "build": "pnpm build:web && pnpm build:electron",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@ngx-translate/core": "^16.0.4",
    "@node-rs/argon2": "^2.0.2",
    "@termsh/angular": "workspace:*",
    "@termsh/common": "workspace:*",
    "@termsh/components": "workspace:*",
    "@termsh/core-napi": "workspace:*",
    "@termsh/platform": "workspace:*",
    "@termsh/state": "workspace:*",
    "@termsh/terminal": "workspace:*",
    "@termsh/vault": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.6.2",
    "keytar": "^7.9.0",
    "node-pty": "^1.0.0",
    "rxjs": "^7.8.2",
    "ssh2": "^1.17.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@types/node": "^22.13.10",
    "@types/ssh2": "^1.15.5",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "app.termsh.desktop",
    "productName": "termsh",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "electron/**/*.js",
      "dist/apps/desktop/browser/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "termsh-co",
      "repo": "clients"
    }
  },
  "license": "AGPL-3.0"
}
