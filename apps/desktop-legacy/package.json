{
  "name": "@termsh/desktop-legacy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-version.mjs",
    "dev": "tauri dev",
    "dev:web": "vite",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc && vite build",
    "prebuild:beta": "node scripts/sync-version.mjs",
    "build:beta": "tauri build --bundles dmg,app",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons": "tauri icon src/assets/brand/app-icon.png && bash scripts/build-macos-icns.sh && bash scripts/build-tray-icons.sh",
    "tray-icons": "bash scripts/build-tray-icons.sh",
    "check": "tsc --noEmit",
    "check-i18n": "node scripts/check-i18n-keys.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@termsh/shared": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "i18next": "^26.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "simple-icons": "^14.12.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^17.4.4",
    "nanoid": "^3.3.12",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.0.5"
  },
  "license": "AGPL-3.0"
}
