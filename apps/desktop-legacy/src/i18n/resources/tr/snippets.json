  "templates": {
    "systemInfo": {
      "title": "Sistem bilgisi",
      "body": "uname -a\necho '---'\ndf -h\necho '---'\nfree -h 2>/dev/null || vm_stat",
      "tags": "system"
    },
    "diskUsage": {
      "title": "Disk kullanımı (ilk 10)",
      "body": "du -sh /* 2>/dev/null | sort -rh | head -10",
      "tags": "system, disk"
    },
    "listeningPorts": {
      "title": "Dinleyen portlar",
      "body": "ss -tlnp 2>/dev/null || netstat -an | grep LISTEN",
      "tags": "network, system"
    },
    "dockerContainers": {
      "title": "Docker konteynerleri",
      "body": "docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'",
      "tags": "docker"
    },
    "dockerCleanup": {
      "title": "Docker temizliği",
      "body": "docker system prune -af --volumes",
      "tags": "docker"
    },
    "gitLog": {
      "title": "Git log (kısa)",
      "body": "git log --oneline --graph --decorate --all -20",
      "tags": "git"
    },
    "topProcesses": {
      "title": "En çok CPU kullanan süreçler",
      "body": "ps aux --sort=-%cpu | head -10",
      "tags": "system"
    },
    "nginxReload": {
      "title": "Nginx yeniden yükle",
      "body": "sudo nginx -t && sudo systemctl reload nginx",
      "tags": "nginx, ops"
    },
    "sslCertCheck": {
      "title": "SSL sertifika kontrolü",
      "body": "echo | openssl s_client -servername example.com -connect example.com:443 2>/dev/null | openssl x509 -noout -dates",
      "tags": "ssl, ops"
    },
    "journalErrors": {
      "title": "Journal hataları (son saat)",
      "body": "journalctl --since '1 hour ago' -p err --no-pager",
      "tags": "system, logs"
    }
  }
