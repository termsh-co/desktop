{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "apps",
  "projects": {
    "desktop": {
      "projectType": "application",
      "root": "apps/desktop",
      "sourceRoot": "apps/desktop/src",
      "prefix": "termsh",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/desktop",
            "index": "apps/desktop/src/index.html",
            "browser": "apps/desktop/src/main.ts",
            "polyfills": [],
            "tsConfig": "apps/desktop/tsconfig.app.json",
            "assets": [
              "apps/desktop/src/assets",
              {
                "glob": "**/*",
                "input": "libs/assets/src/i18n",
                "output": "/assets/i18n"
              }
            ],
            "styles": ["apps/desktop/src/styles/tokens.css", "apps/desktop/src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "desktop:build"
          }
        }
      }
    },
    "web": {
      "projectType": "application",
      "root": "apps/web",
      "sourceRoot": "apps/web/src",
      "prefix": "termsh",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/web",
            "index": "apps/web/src/index.html",
            "browser": "apps/web/src/main.ts",
            "polyfills": [],
            "tsConfig": "apps/web/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/web/public",
                "output": "/"
              }
            ],
            "styles": ["apps/web/src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "web:build"
          }
        }
      }
    },
    "components": {
      "projectType": "library",
      "root": "libs/components",
      "sourceRoot": "libs/components/src",
      "prefix": "termsh",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "libs/components/ng-package.json"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "054934c8-0604-4c8f-8808-759e88ea03b6"
  }
}
