# ── Sync server — see server/.env.example ──

# ── macOS imzalama + notarization (opsiyonel — yoksa yerel ad-hoc / imzasız build) ──
# https://v2.tauri.app/distribute/sign/macos/

# Developer ID Application: Your Name (TEAMID)
# APPLE_SIGNING_IDENTITY=
# TAURI_SIGNING_PRIVATE_KEY=   # updater için (Faz 1b)

# Notarization — Apple ID
# APPLE_ID=
# APPLE_PASSWORD=              # app-specific password
# APPLE_TEAM_ID=

# Notarization — App Store Connect API (alternatif)
# APPLE_API_ISSUER=
# APPLE_API_KEY=
# APPLE_API_KEY_PATH=
